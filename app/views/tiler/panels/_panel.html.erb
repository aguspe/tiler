<% # `data` may not be passed (e.g. when this partial is rendered by Turbo's
   # broadcasts_to callback). Fall back to computing it from the widget so the
   # partial is safe to render in any context. %>
<% data = local_assigns.key?(:data) ? local_assigns[:data] : panel.data %>
<%= turbo_frame_tag "tiler_panel_#{panel.id}" do %>
  <div class="tiler-panel">
    <div class="tiler-panel-header">
      <h3><%= panel.title %></h3>
      <div class="tiler-panel-actions">
        <span class="tiler-tag"><%= panel.widget_label %></span>
        <%= link_to "Edit", edit_dashboard_panel_path(panel.dashboard, panel),
              class: "tiler-link",
              data: { turbo_frame: "_top" } %>
      </div>
    </div>
    <div class="tiler-panel-body">
      <% widget = panel.widget %>
      <% if data.nil? || widget.empty?(data) %>
        <div class="tiler-panel-empty">
          <p class="tiler-muted">No data yet. Configure this panel to get started.</p>
          <% if panel.data_source.nil? %>
            <p class="tiler-muted tiler-text-sm">Tip: this widget needs a data source. Open Edit and pick one.</p>
          <% end %>
          <%= link_to "Edit panel", edit_dashboard_panel_path(panel.dashboard, panel),
                class: "tiler-btn tiler-btn-sm",
                data: { turbo_frame: "_top" } %>
        </div>
      <% else %>
        <%= render partial: widget.partial, locals: { panel: panel, data: data } %>
      <% end %>
    </div>
  </div>
<% end %>
