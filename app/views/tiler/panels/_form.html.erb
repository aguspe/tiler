<% widget_klass = Tiler.widgets[panel.widget_type] || Tiler.widgets[Tiler.widgets.types.first] %>
<% example_config = widget_klass.example_config.to_json %>
<% example_payload = widget_klass.example_payload.to_json %>

<%= form_with(model: panel,
              url: panel.persisted? ? dashboard_panel_path(@dashboard, panel) : dashboard_panels_path(@dashboard),
              local: true, data: { turbo: false }, class: "tiler-form", id: "tiler-panel-form") do |f| %>
  <% if panel.errors.any? %>
    <div class="tiler-form-errors">
      <ul><% panel.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>

  <div class="tiler-field">
    <%= f.label :title %>
    <%= f.text_field :title, required: true %>
  </div>

  <div class="tiler-field">
    <%= f.label :widget_type %>
    <%= f.select :widget_type, widget_type_options %>
  </div>

  <div class="tiler-field">
    <%= f.label :tiler_data_source_id, "Data source" %>
    <%= f.select :tiler_data_source_id,
                 @data_sources.map { |s| [ s.name, s.id ] },
                 include_blank: "— none —" %>
  </div>

  <div class="tiler-field-row">
    <div class="tiler-field">
      <%= f.label :width, "Width (1–12)" %>
      <%= f.number_field :width, min: 1, max: 12 %>
    </div>
    <div class="tiler-field">
      <%= f.label :height, "Height (1–12)" %>
      <%= f.number_field :height, min: 1, max: 12 %>
    </div>
  </div>
  <p class="tiler-hint">You can also drag &amp; resize panels directly on the dashboard.</p>

  <% has_example = widget_klass.example_config.is_a?(Hash) && widget_klass.example_config.any? %>
  <% data_backed = !widget_klass.query_class.nil? %>

  <div class="tiler-field">
    <%= f.label :config, "Config (JSON)" %>
    <%= f.text_area :config, rows: 8, placeholder: (has_example ? example_config : "{}") %>
    <% if has_example %>
      <div class="tiler-example-config-row"
           data-controller="tiler--clipboard"
           data-tiler--clipboard-text-value="<%= example_config %>">
        <span class="tiler-hint">Example for <%= widget_klass.label %>:</span>
        <code data-tiler-example-config><%= example_config %></code>
        <button type="button" class="tiler-btn tiler-btn-sm" data-tiler-copy
                data-action="click->tiler--clipboard#copy">Copy</button>
      </div>
    <% end %>
    <% if data_backed %>
      <p class="tiler-hint">
        Tip: paste any static JSON here to <strong>preview</strong> the widget without a data source — useful for quickly trying different shapes.
      </p>
    <% end %>
  </div>

  <details class="tiler-info" data-tiler-info open>
    <summary>How do I push data into this widget?</summary>
    <% data_source = panel.data_source || (panel.tiler_data_source_id && Tiler::DataSource.find_by(id: panel.tiler_data_source_id)) %>
    <% if data_source.nil? %>
      <p class="tiler-muted">No data source attached. Pick one above, or <%= link_to "manage Data Sources", data_sources_path, class: "tiler-link" %> to create one and enable webhook ingestion.</p>
    <% else %>
      <% endpoint_url = "#{request.protocol}#{request.host_with_port}/tiler/ingest/#{data_source.slug}" %>
      <p>Push records via HTTP POST to:</p>
      <div class="tiler-copy-row" data-controller="tiler--clipboard"
           data-tiler--clipboard-text-value="<%= endpoint_url %>">
        <pre class="tiler-code-block"><%= endpoint_url %></pre>
        <button type="button" class="tiler-btn tiler-btn-sm" data-tiler-copy
                data-action="click->tiler--clipboard#copy">Copy</button>
      </div>
      <p>Header (treat as an API key):</p>
      <div class="tiler-copy-row" data-controller="tiler--clipboard"
           data-tiler--clipboard-text-value="<%= data_source.webhook_token %>">
        <pre class="tiler-code-block">X-Tiler-Token: <%= data_source.webhook_token %></pre>
        <button type="button" class="tiler-btn tiler-btn-sm" data-tiler-copy
                data-action="click->tiler--clipboard#copy">Copy</button>
      </div>
      <p>Sample payload for the <strong><%= widget_klass.label %></strong> widget:</p>
      <% payload_pretty = JSON.pretty_generate(JSON.parse(example_payload)) %>
      <div class="tiler-copy-row" data-controller="tiler--clipboard"
           data-tiler--clipboard-text-value="<%= payload_pretty %>">
        <pre class="tiler-code-block"><%= payload_pretty %></pre>
        <button type="button" class="tiler-btn tiler-btn-sm" data-tiler-copy
                data-action="click->tiler--clipboard#copy">Copy</button>
      </div>
      <% curl_cmd = "curl -X POST #{endpoint_url} \\\n  -H \"X-Tiler-Token: #{data_source.webhook_token}\" \\\n  -H \"Content-Type: application/json\" \\\n  -d '#{example_payload}'" %>
      <p>Example curl:</p>
      <div class="tiler-copy-row" data-controller="tiler--clipboard"
           data-tiler--clipboard-text-value="<%= curl_cmd %>">
        <pre class="tiler-code-block"><%= curl_cmd %></pre>
        <button type="button" class="tiler-btn tiler-btn-sm" data-tiler-copy
                data-action="click->tiler--clipboard#copy">Copy</button>
      </div>
    <% end %>
  </details>

  <div class="tiler-form-actions">
    <button type="submit" class="tiler-btn tiler-btn-primary">
      <%= panel.persisted? ? "Update Panel" : "Create Panel" %>
    </button>
    <% if panel.persisted? %>
      <button type="button"
              class="tiler-btn tiler-btn-danger"
              data-tiler-delete
              data-controller="tiler--modal"
              data-action="click->tiler--modal#open"
              data-tiler--modal-message-value="Remove this panel? This cannot be undone."
              data-tiler--modal-confirm-label-value="Delete panel"
              data-tiler--modal-action-value="<%= dashboard_panel_path(@dashboard, panel) %>"
              data-tiler--modal-method-value="delete">Delete Panel</button>
    <% end %>
  </div>
<% end %>
