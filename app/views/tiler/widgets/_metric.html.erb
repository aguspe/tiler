<div class="tiler-metric">
  <div class="tiler-metric-value">
    <% raw_value = data[:value] %>
    <% formatted = raw_value.is_a?(Numeric) ? number_with_delimiter(raw_value) : (raw_value || "—") %>
    <% if data[:prefix].to_s.present? %><span class="tiler-metric-affix"><%= data[:prefix] %></span><% end %><span class="tiler-metric-number"><%= formatted %></span><% if data[:suffix].to_s.present? %><span class="tiler-metric-affix"><%= data[:suffix] %></span><% end %>
  </div>
  <div class="tiler-metric-label"><%= data[:label] %></div>
  <% if data[:time_window].present? && data[:time_window] != "all" %>
    <div class="tiler-metric-window">last <%= data[:time_window] %></div>
  <% end %>
</div>
