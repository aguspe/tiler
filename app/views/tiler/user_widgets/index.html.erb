<% content_for :title, "Custom widgets" %>
<%= link_to "← Back to Settings", settings_path, class: "tiler-link" %>
<div class="tiler-page-header">
  <div>
    <h1>Custom widgets</h1>
    <p class="tiler-muted">No-code widgets defined with a Liquid template. Auto-registered on save.</p>
  </div>
  <div class="tiler-page-header-actions">
    <%= link_to "+ New custom widget", new_user_widget_path,
          class: "tiler-btn tiler-btn-primary" %>
  </div>
</div>

<% if @user_widgets.empty? %>
  <div class="tiler-empty">
    <p>No custom widgets yet.</p>
    <%= link_to "Create your first one", new_user_widget_path,
          class: "tiler-btn tiler-btn-primary" %>
  </div>
<% else %>
  <div class="tiler-table-scroll tiler-user-widgets-table">
    <table class="tiler-table">
      <thead>
        <tr>
          <th>Slug</th>
          <th>Label</th>
          <th>Data</th>
          <th class="tiler-table-num">Default size</th>
          <th class="tiler-table-actions"></th>
        </tr>
      </thead>
      <tbody>
        <% @user_widgets.each do |uw| %>
          <tr class="tiler-user-widget-row"
              data-tiler-user-widget-row="<%= uw.slug %>"
              data-controller="tiler--row-link"
              data-tiler--row-link-url-value="<%= edit_user_widget_path(uw) %>"
              data-action="click->tiler--row-link#go"
              tabindex="0">
            <td><code><%= uw.registry_slug %></code></td>
            <td><%= uw.label %></td>
            <td><%= uw.data_kind.humanize %></td>
            <td class="tiler-table-num"><%= uw.default_w %>×<%= uw.default_h %></td>
            <td class="tiler-table-actions" data-tiler-row-link-skip>
              <%= link_to "Edit", edit_user_widget_path(uw),
                    class: "tiler-btn tiler-btn-sm" %>
              <button type="button"
                      class="tiler-btn tiler-btn-sm tiler-btn-danger"
                      data-tiler-user-widget-delete
                      data-controller="tiler--modal"
                      data-action="click->tiler--modal#open"
                      data-tiler--modal-message-value="Delete custom widget '<%= uw.slug %>'? Existing panels using it will show 'no longer exists'."
                      data-tiler--modal-confirm-label-value="Delete widget"
                      data-tiler--modal-action-value="<%= user_widget_path(uw) %>"
                      data-tiler--modal-method-value="delete">Delete</button>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
