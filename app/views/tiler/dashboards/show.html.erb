<% content_for :title, @dashboard.name %>

<div data-controller="tiler--drawer"
     data-tiler--drawer-frame-id-value="tiler_panel_edit_drawer">
  <div class="tiler-drawer-backdrop"
       data-tiler--drawer-target="backdrop"
       data-action="click->tiler--drawer#close"></div>
  <aside class="tiler-drawer"
         role="dialog"
         aria-label="Edit Panel"
         data-tiler-drawer
         data-tiler--drawer-target="panel">
    <%= turbo_frame_tag "tiler_panel_edit_drawer", class: "tiler-drawer-frame" %>
  </aside>

<div class="tiler-dashboard"
     data-controller="tiler--dashboard-grid"
     data-tiler--dashboard-grid-layout-url-value="<%= layout_dashboard_path(@dashboard) %>"
     data-tiler--dashboard-grid-panels-url-value="<%= dashboard_panels_path(@dashboard) %>"
     data-tiler--dashboard-grid-csrf-value="<%= form_authenticity_token %>"
     data-tiler--dashboard-grid-refresh-seconds-value="<%= @dashboard.refresh_seconds %>"
     data-tiler--dashboard-grid-disable-polling-value="<%= Tiler.configuration.disable_polling %>"
     <% style = @dashboard.theme_inline_style %>
     <% if style.present? %>style="<%= style %>"<% end %>>
  <%= turbo_stream_from @dashboard %>
  <% unless @tv_mode %>
    <div class="tiler-page-header">
      <div>
        <h1 class="tiler-dashboard-title"
            data-tiler-dashboard-title
            data-controller="tiler--inline-edit"
            data-tiler--inline-edit-url-value="<%= api_v1_dashboard_path(@dashboard.slug, format: :json) %>"
            data-tiler--inline-edit-csrf-value="<%= form_authenticity_token %>"
            data-tiler--inline-edit-field-value="name"
            data-tiler--inline-edit-resource-value="dashboard"
            data-action="dblclick->tiler--inline-edit#edit
                         keydown->tiler--inline-edit#onKey
                         blur->tiler--inline-edit#save"
            title="Double-click to rename"
            tabindex="0"><%= @dashboard.name %></h1>
        <% if @dashboard.description.present? %>
          <p class="tiler-muted"><%= @dashboard.description %></p>
        <% end %>
        <div class="tiler-page-header-actions">
          <button type="button"
                  class="tiler-btn tiler-btn-primary tiler-btn-sm"
                  data-tiler-add-panel
                  data-tiler--dashboard-grid-target="toggle"
                  data-action="click->tiler--dashboard-grid#togglePalette">Add Panel</button>
        </div>
      </div>
    </div>
  <% end %>

  <% unless @tv_mode %>
  <details class="tiler-about" data-tiler-about open>
    <summary>About this dashboard</summary>
    <p><strong>Tiler</strong> is a plug-and-play dashboards engine for Rails. Each tile is a <strong>widget</strong> that pulls from a <strong>data source</strong>.</p>
    <p>To populate a widget you can either:</p>
    <ul class="tiler-about-list">
      <li>Push records via the data source's webhook — click any tile's header → <em>How do I push data</em> for a one-line curl.</li>
      <li>Paste a static JSON config to preview a widget instantly without a data source.</li>
    </ul>
    <p class="tiler-muted">
      <strong>Drag</strong> a tile to move it. <strong>Resize</strong> by dragging any edge or corner — every tile snaps to the 12-column grid (min 1, max 12 across or down). Click <strong>Add Panel</strong> to drop in new widgets from the palette. <strong>Click</strong> a tile's header to edit it.
    </p>
  </details>
  <% end %>

  <% panels = @dashboard.panels %>

  <% if panels.empty? %>
    <div class="tiler-empty">
      <p>No panels yet.</p>
      <%= link_to "Add your first panel", new_dashboard_panel_path(@dashboard),
            class: "tiler-btn tiler-btn-primary" %>
    </div>
  <% else %>
    <div class="tiler-dashboard-shell" data-tiler--dashboard-grid-target="shell">
      <aside class="tiler-widget-palette" data-tiler-palette aria-label="Widget palette">
        <h4 class="tiler-widget-palette-title">Widgets</h4>
        <div class="tiler-widget-palette-list" role="list">
          <% Tiler.widgets.each do |type, klass| %>
            <% w = klass.default_size[:w] || klass.default_size["w"] %>
            <% h = klass.default_size[:h] || klass.default_size["h"] %>
            <div class="tiler-widget-palette-item grid-stack-item"
                 data-tiler-palette-widget
                 data-widget-type="<%= type %>"
                 data-default-w="<%= w %>"
                 data-default-h="<%= h %>"
                 data-default-config="<%= klass.default_config.to_json %>"
                 gs-w="<%= w %>"
                 gs-h="<%= h %>"
                 draggable="true"
                 tabindex="0"
                 role="listitem"
                 data-action="dragstart->tiler--dashboard-grid#paletteDragStart dragend->tiler--dashboard-grid#paletteDragEnd">
              <span class="tiler-widget-palette-label"><%= klass.label %></span>
            </div>
          <% end %>
        </div>
      </aside>

      <div id="tiler-grid-stack-<%= @dashboard.id %>" class="grid-stack tiler-grid-stack"
           data-tiler-dashboard-id="<%= @dashboard.id %>"
           data-tiler-layout-url="<%= layout_dashboard_path(@dashboard) %>"
           data-tiler-csrf="<%= form_authenticity_token %>"
           data-tiler-panels-url="<%= dashboard_panels_path(@dashboard) %>"
           data-tiler--dashboard-grid-target="grid"
           <% if @dashboard.refresh_seconds > 0 %>
             data-tiler-refresh="<%= @dashboard.refresh_seconds %>"
           <% end %>>
        <% panels.each do |panel| %>
          <% pwk    = Tiler.widgets[panel.widget_type] %>
          <% pmin   = (pwk&.min_size || { w: 1, h: 1 }) %>
          <% pmax   = (pwk&.max_size || { w: 12, h: 12 }) %>
          <% pminw  = pmin[:w] || pmin["w"] || 1 %>
          <% pminh  = pmin[:h] || pmin["h"] || 1 %>
          <% pmaxw  = pmax[:w] || pmax["w"] || 12 %>
          <% pmaxh  = pmax[:h] || pmax["h"] || 12 %>
          <div class="grid-stack-item"
               gs-id="<%= panel.id %>"
               gs-x="<%= panel.x %>"
               gs-y="<%= panel.y %>"
               gs-w="<%= panel.width %>"
               gs-h="<%= panel.height %>"
               gs-min-w="<%= pminw %>"
               gs-min-h="<%= pminh %>"
               gs-max-w="<%= pmaxw %>"
               gs-max-h="<%= pmaxh %>">
            <div class="grid-stack-item-content">
              <%= turbo_frame_tag "tiler_panel_#{panel.id}",
                    src: preview_dashboard_panel_path(@dashboard, panel),
                    loading: (Tiler.configuration.eager_panel_load ? :eager : :lazy) do %>
                <div class="tiler-skeleton">
                  <div class="tiler-skeleton-title"></div>
                  <div class="tiler-skeleton-body"></div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
</div>
