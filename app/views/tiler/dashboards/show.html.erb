<% content_for :title, @dashboard.name %>

<div class="tiler-dashboard"
     data-controller="tiler--dashboard-grid"
     data-tiler--dashboard-grid-layout-url-value="<%= layout_dashboard_path(@dashboard) %>"
     data-tiler--dashboard-grid-panels-url-value="<%= dashboard_panels_path(@dashboard) %>"
     data-tiler--dashboard-grid-csrf-value="<%= form_authenticity_token %>"
     data-tiler--dashboard-grid-refresh-seconds-value="<%= @dashboard.refresh_seconds %>"
     data-tiler--dashboard-grid-disable-polling-value="<%= Tiler.configuration.disable_polling %>">
  <%= turbo_stream_from @dashboard %>
  <div class="tiler-page-header">
    <div>
      <h1><%= @dashboard.name %></h1>
      <% if @dashboard.description.present? %>
        <p class="tiler-muted"><%= @dashboard.description %></p>
      <% end %>
    </div>
    <div>
      <button type="button"
              class="tiler-btn tiler-btn-primary"
              data-tiler-add-panel
              data-tiler--dashboard-grid-target="toggle"
              data-action="click->tiler--dashboard-grid#togglePalette">Add Panel</button>
    </div>
  </div>

  <% panels = @dashboard.panels %>

  <% if panels.empty? %>
    <div class="tiler-empty">
      <p>No panels yet.</p>
      <%= link_to "Add your first panel", new_dashboard_panel_path(@dashboard),
            class: "tiler-btn tiler-btn-primary" %>
    </div>
  <% else %>
    <div class="tiler-dashboard-shell" data-tiler--dashboard-grid-target="shell">
      <aside class="tiler-widget-palette" data-tiler-palette aria-label="Widget palette">
        <h4 class="tiler-widget-palette-title">Widgets</h4>
        <div class="tiler-widget-palette-list" role="list">
          <% Tiler.widgets.each do |type, klass| %>
            <% w = klass.default_size[:w] || klass.default_size["w"] %>
            <% h = klass.default_size[:h] || klass.default_size["h"] %>
            <div class="tiler-widget-palette-item grid-stack-item"
                 data-tiler-palette-widget
                 data-widget-type="<%= type %>"
                 data-default-w="<%= w %>"
                 data-default-h="<%= h %>"
                 data-default-config="<%= klass.default_config.to_json %>"
                 gs-w="<%= w %>"
                 gs-h="<%= h %>"
                 draggable="true"
                 tabindex="0"
                 role="listitem"
                 data-action="dragstart->tiler--dashboard-grid#paletteDragStart dragend->tiler--dashboard-grid#paletteDragEnd">
              <span class="tiler-widget-palette-label"><%= klass.label %></span>
            </div>
          <% end %>
        </div>
      </aside>

      <div id="tiler-grid-stack-<%= @dashboard.id %>" class="grid-stack tiler-grid-stack"
           data-tiler-dashboard-id="<%= @dashboard.id %>"
           data-tiler-layout-url="<%= layout_dashboard_path(@dashboard) %>"
           data-tiler-csrf="<%= form_authenticity_token %>"
           data-tiler-panels-url="<%= dashboard_panels_path(@dashboard) %>"
           data-tiler--dashboard-grid-target="grid"
           <% if @dashboard.refresh_seconds > 0 %>
             data-tiler-refresh="<%= @dashboard.refresh_seconds %>"
           <% end %>>
        <% panels.each do |panel| %>
          <div class="grid-stack-item"
               gs-id="<%= panel.id %>"
               gs-x="<%= panel.x %>"
               gs-y="<%= panel.y %>"
               gs-w="<%= panel.width %>"
               gs-h="<%= panel.height %>">
            <div class="grid-stack-item-content">
              <%= turbo_frame_tag "tiler_panel_#{panel.id}",
                    src: preview_dashboard_panel_path(@dashboard, panel),
                    loading: (Tiler.configuration.eager_panel_load ? :eager : :lazy) do %>
                <div class="tiler-skeleton">
                  <div class="tiler-skeleton-title"></div>
                  <div class="tiler-skeleton-body"></div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
