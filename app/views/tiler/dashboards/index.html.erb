<% content_for :title, "Dashboards" %>
<div class="tiler-page-header">
  <h1>Dashboards</h1>
  <%= link_to "New Dashboard", new_dashboard_path, class: "tiler-btn tiler-btn-primary" %>
</div>

<% if @dashboards.empty? %>
  <div class="tiler-empty">
    <p>No dashboards yet.</p>
    <%= link_to "Create your first dashboard", new_dashboard_path, class: "tiler-btn" %>
  </div>
<% else %>
  <ul class="tiler-card-grid">
    <% @dashboards.each do |d| %>
      <li class="tiler-card tiler-card-deletable" data-tiler-dashboard-card="<%= d.slug %>">
        <button type="button"
                class="tiler-card-delete"
                aria-label="Delete <%= d.name %>"
                title="Delete dashboard"
                data-tiler-dashboard-delete
                data-controller="tiler--modal"
                data-action="click->tiler--modal#open"
                data-tiler--modal-message-value="Delete &quot;<%= d.name %>&quot;? This removes the dashboard and all its panels — cannot be undone."
                data-tiler--modal-confirm-label-value="Delete dashboard"
                data-tiler--modal-action-value="<%= dashboard_path(d) %>"
                data-tiler--modal-method-value="delete">×</button>
        <h3><%= link_to d.name, dashboard_path(d) %></h3>
        <p class="tiler-muted"><%= d.description %></p>
        <p class="tiler-meta"><%= pluralize(d.panels.size, "panel") %></p>
      </li>
    <% end %>
  </ul>
<% end %>
