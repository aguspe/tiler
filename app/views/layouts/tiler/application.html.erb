<!DOCTYPE html>
<html>
<head>
  <title><%= content_for?(:title) ? yield(:title) : "Tiler" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "tiler/application", media: "all" %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/gridstack@10.3.1/dist/gridstack.min.css">
  <% if respond_to?(:javascript_importmap_tags) && Rails.application.respond_to?(:importmap) %>
    <%= javascript_importmap_tags %>
  <% else %>
    <%= javascript_include_tag "turbo", type: "module" %>
  <% end %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/gridstack@10.3.1/dist/gridstack-all.js"></script>
  <%= yield :head %>
</head>
<body>
  <nav class="tiler-nav">
    <%= link_to "Dashboards", dashboards_path, class: "tiler-nav-link" %>
    <%= link_to "Data Sources", data_sources_path, class: "tiler-nav-link" %>
  </nav>
  <% flash.each do |k, msg| %>
    <div class="tiler-flash tiler-flash-<%= k %>"
         data-controller="tiler--flash"
         data-tiler--flash-timeout-value="5000"
         role="status"
         aria-live="polite">
      <span class="tiler-flash-message"><%= msg %></span>
      <button type="button"
              class="tiler-flash-close"
              data-tiler-flash-close
              data-action="click->tiler--flash#dismiss"
              aria-label="Dismiss">&times;</button>
    </div>
  <% end %>
  <main class="tiler-main"><%= yield %></main>
</body>
</html>
